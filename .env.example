# ========================================
# AI 周报系统 - 环境变量配置模板
# ========================================
# 使用方法：
#   1. 复制本文件为 .env
#   2. 填入对应的 API Key 和密码
#   3. 运行 `python weekly_report.py` 会自动加载 .env
#
# 注意：.env 文件已在 .gitignore 中忽略，不会提交到 git
# ========================================

# ---------- AI Provider API Keys ----------
# 选择一个或多个 provider 填入对应的 API Key
# 代码会自动覆盖 config.json 中的 api_key 字段

# MiniMax (https://platform.minimaxi.com/)
MINIMAX_API_KEY=

# DeepSeek (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=

# OpenCode Zen (https://opencode.ai/)
OPENCODE_API_KEY=

# 阿里云通义千问 Qwen (https://dashscope.console.aliyun.com/)
QWEN_API_KEY=

# ---------- 邮箱配置 ----------
# 腾讯企业邮箱发件人地址（如 yourname@company.com）
EMAIL_SENDER=

# 腾讯企业邮箱客户端专用密码（16位，不是登录密码！）
# 获取方式：企业邮箱 → 设置 → 客户端 → 客户端专用密码 → 生成
EMAIL_PASSWORD=

# ---------- CRM 工时接口配置 ----------
# CRM 接口 authorization Bearer 后的 JWT token（敏感，避免明文存储在 config.json）
# 获取方式：登录你的 CRM 系统 → F12 抓包 exportWorkHourItems 请求 →
#           复制 authorization 头中 "Bearer:" 后面的完整字符串
# 注意：token 失效时会自动调用 login_url 用账号密码重新登录刷新，无需手动维护
CRM_TOKEN=

# CRM 登录账号（如 T0265），用于 token 失效时自动刷新
CRM_USERNAME=

# CRM 登录密码（加密后的字符串，敏感）
# 获取方式：在浏览器登录 CRM 时 F12 抓包 userLoginPlm 请求，复制 body 中 password 字段值
CRM_PASSWORD=

# ---------- Excel 文件夹路径 ----------
# 可选：覆盖 config.json 中的 excel_folder
# EXCEL_FOLDER=D:/path/to/excel_files
